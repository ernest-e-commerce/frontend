# ============================================================================
# Supabase Postgres connection — pick ONE of the two options below.
# ============================================================================

# OPTION A — Individual fields (recommended; no URL encoding needed for password)
# Find these in Supabase Dashboard -> Project Settings -> Database -> Connection info
SUPABASE_DB_HOST=db.wrkoktcdyigsjlsrhpqh.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=H!ghsc@re2541?
SUPABASE_DB_NAME=postgres



# OPTION B — Single connection string (only if Option A is unset)
# WARNING: special characters in password (@, #, $, !, etc.) MUST be URL-encoded.
#   @ -> %40    # -> %23    $ -> %24    ! -> %21    & -> %26    : -> %3A    / -> %2F
# DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASS@db.wrkoktcdyigsjlsrhpqh.supabase.co:5432/postgres
